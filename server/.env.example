# Supabase connection via PgBouncer (transaction pooler) — used at runtime
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Direct (non-pooled) connection — used by Prisma migrations and db pull
DIRECT_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-us-east-2.pooler.supabase.com:5432/postgres

PORT=3000
NODE_ENV=development

# Better Auth — server-side auth (Bloco 2)
# Secret used to sign sessions/cookies. Generate with one of:
#   openssl rand -base64 32
#   npx @better-auth/cli secret
BETTER_AUTH_SECRET=GENERATE_A_32_BYTE_SECRET
# Base URL the auth server runs on (used for cookies + callbacks).
BETTER_AUTH_URL=http://localhost:3000
# Frontend origin, added to Better Auth trustedOrigins (CSRF allow-list).
# Dev: the Vite client at :5173 (proxies /api to :3000).
CLIENT_URL=http://localhost:5173
