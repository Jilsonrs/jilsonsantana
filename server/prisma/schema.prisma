// Prisma schema — source of truth for all DB models.
// Run "npm --workspace server run db:pull" (with DATABASE_URL set) to sync from Supabase.
// Run "npm --workspace server run db:generate" after any schema change.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Phase 2 — content-model enums. Mirror core/src/constants/content.ts 1:1 (the
// shared `as const` values drive client + Zod; these Postgres enums enforce at
// the DB). Keep both sides in lockstep when adding a value.
enum Level {
  INICIANTE
  INTERMEDIARIO
  AVANCADO
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum Layer {
  UNIVERSAL
  MODERNO
  IA
}

enum PlanItemType {
  COURSE
  LESSON
}

// Phase 1: Better Auth tables (user, session, account, verification).
// Models below are generated by the Better Auth CLI (`@better-auth/cli generate`)
// — it is the source of truth for the BA schema; do not hand-edit these models.
// Legacy tables (users, sessions) live only in the DB and are dropped in this
// phase's migration.

model User {
  id            String         @id
  // DEBT: o Better Auth CLI gera `name` como required (String). Mantido opcional
  // (String?) para respeitar o CLAUDE.md (name opcional — convite corporativo só
  // por e-mail). REAPLICAR `String?` após cada `@better-auth/cli generate`.
  name          String?
  email         String
  emailVerified Boolean        @default(false)
  image         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  role          String         @default("member")
  sessions      Session[]
  accounts      Account[]
  // Phase 2 back-relation: a member's saved/cloned trilhas (curated templates
  // have ownerUserId = null and are not listed here). Hand-added like sessions/
  // accounts — REAPPLY after each `@better-auth/cli generate` (same DEBT note as
  // `name String?` above; the CLI does not emit our relations).
  learningPlans LearningPlan[]

  birthday            String?
  preferredLanguage   String?   @default("pt")
  marketingConsent    Boolean?  @default(false)
  acquisitionSource   String?
  acquisitionCampaign String?
  deletedAt           DateTime?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ── Phase 2: Content model (Course → Module → Lesson) + Trilhas ──────────────
// Content entities use Int autoincrement IDs (route handlers parse them via the
// shared parseId helper — Block 2). Better Auth tables keep their String IDs.
// RLS is ENABLEd on every table below in the migration (Prisma does not emit it);
// no policies — Prisma connects via a BYPASSRLS role and is the sole accessor.

// A course. The detail page is light by design (catalog, not a heavy sales page):
// most fields are optional, filled per course by the operator. Derived data
// (carga horária, lesson count, 3-camadas grouping) is computed, never stored.
model Course {
  id             Int           @id @default(autoincrement())
  slug           String        @unique
  title          String
  subtitle       String?
  description    String?
  level          Level?
  learnTags      String[]      @default([]) // "o que você vai aprender" — clickable pills
  requirements   String[]      @default([]) // pré-requisitos, shown openly
  personas       String[]      @default([]) // "pra quem é"
  highlights     Json? // [{ icon, title, text }] — "diferenciais" icon cards
  faq            Json? // [{ pergunta, resposta }] — optional; renders only if filled
  camadas        Layer[]       @default([]) // which 3-camadas layers this course shows (0–3)
  camadaOverride Json? // per-course layer text override (exception, e.g. N8N)
  thumbnailUrl   String? // catalog/list image
  introVideoId   String? // presentation video (Bunny); non-gated wiring is Phase 3
  displayOrder   Int           @default(0)
  status         ContentStatus @default(DRAFT)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  modules        Module[]
  planItems      PlanItem[]

  @@map("course")
}

model Module {
  id           Int           @id @default(autoincrement())
  courseId     Int
  course       Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title        String
  layer        Layer? // optional single layer tag (post-launch: group accordion by it)
  displayOrder Int           @default(0)
  status       ContentStatus @default(DRAFT)
  lessons      Lesson[]

  @@index([courseId])
  @@map("module")
}

// First-class & searchable: a lesson has its own title + tags and can surface in
// search results or sit inside a trilha on its own, not only nested in a course.
// Progress counts per lesson (Phase 5). bunnyVideoId is added in Phase 3.
model Lesson {
  id           Int           @id @default(autoincrement())
  moduleId     Int
  module       Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title        String
  tags         String[]      @default([])
  displayOrder Int           @default(0)
  status       ContentStatus @default(DRAFT)
  planItems    PlanItem[]

  @@index([moduleId])
  @@map("lesson")
}

// A trilha (learning track). Curated template (ownerUserId = null, isTemplate)
// and a member's personalized/cloned plan are the SAME entity — only ownership
// differs. AI-assembled plans (buildLearningPlan) land in JilsonAI Fase 4–5 with
// no rewrite. skillsCovered is the snapshot the certificate prints.
model LearningPlan {
  id            Int            @id @default(autoincrement())
  slug          String?        @unique // curated templates get a slug; clones may not
  name          String
  description   String?
  ownerUserId   String? // null = curated template
  owner         User?          @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  isTemplate    Boolean        @default(false)
  skillsCovered String[]       @default([])
  sourcePlanId  Int? // provenance: which template this clone came from
  sourcePlan    LearningPlan?  @relation("PlanClone", fields: [sourcePlanId], references: [id], onDelete: SetNull)
  clones        LearningPlan[] @relation("PlanClone")
  displayOrder  Int            @default(0)
  status        ContentStatus  @default(DRAFT)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  planModules   PlanModule[]

  @@index([ownerUserId])
  @@map("learning_plan")
}

model PlanModule {
  id           Int          @id @default(autoincrement())
  planId       Int
  plan         LearningPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  title        String
  displayOrder Int          @default(0)
  items        PlanItem[]

  @@index([planId])
  @@map("plan_module")
}

// The free mix: an item is EITHER a whole course OR a standalone lesson. A DB
// CHECK constraint (added in the migration) enforces the XOR so itemType always
// matches exactly one populated FK.
model PlanItem {
  id           Int          @id @default(autoincrement())
  planModuleId Int
  planModule   PlanModule   @relation(fields: [planModuleId], references: [id], onDelete: Cascade)
  itemType     PlanItemType
  courseId     Int?
  course       Course?      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonId     Int?
  lesson       Lesson?      @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  displayOrder Int          @default(0)

  @@index([planModuleId])
  @@index([courseId])
  @@index([lessonId])
  @@map("plan_item")
}
